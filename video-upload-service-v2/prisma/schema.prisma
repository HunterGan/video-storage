generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VideoStatus {
  UPLOADED
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum VideoQuality {
  SD
  HD
}

model Video {
  id            String         @id @default(uuid())
  title         String
  description   String?
  url           String
  s3_key        String         @unique
  processed_url String?
  poster_url    String?
  status                  VideoStatus    @default(UPLOADED)
  processing_started_at   DateTime?
  processing_finished_at  DateTime?
  error_message           String?
  duration                Float?
  created_at              DateTime      @default(now())
  updated_at              DateTime      @updatedAt
  versions                VideoVersion[]
  @@map("videos")
  @@index([created_at])
  @@index([s3_key])
  @@index([status])
}

model VideoVersion {
  id        String    @id @default(uuid())
  video_id  String
  quality   VideoQuality @default(HD)
  url       String
  width     Int?
  height    Int?
  file_size BigInt?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  video     Video    @relation(fields: [video_id], references: [id], onDelete: Cascade)
  @@map("video_versions")
  @@index([video_id])
  @@index([quality])
}
