# Backend Configuration
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=postgresql://video_user:video_pass@postgres:5432/video_upload_db

# S3 Configuration (Selectel Object Storage)
S3_ENDPOINT=s3.ru-3.storage.selcloud.ru
S3_REGION=ru-3
S3_BUCKET=bucket-name
S3_ACCESS_KEY=0987654321
S3_SECRET_KEY=123456789
CDN_BASE_URL=https://abcdefg.selstorage.ru/videos

# Video Upload Settings
MAX_FILE_SIZE_MB=500
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/quicktime,video/x-msvideo,video/x-matroska
PRESIGNED_URL_TTL_SECONDS=3600

# Security & Performance
CORS_ALLOWED_ORIGINS=
RATE_LIMIT_REQUESTS_PER_SECOND=100
ENABLE_REQUEST_ID=true
RUST_LOG=video_upload_service=debug,tower_http=debug

# Database Configuration
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_pass
POSTGRES_DB=video_upload_db

# Frontend Environment Variables (passed during build)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_KEY=api-key
VITE_API_TIMEOUT=60000